          "match": "(?i)\\b(?:divpd|divps|divsd|divss|dppd|dpps|daa|das|dec|div)\\b"
        },
        {
          "name": "keyword.control.instruction.e.x86asm",
          "match": "(?i)\\b(?:edecvirtchild|eincvirtchild|encodekey128|encodekey256|eacceptcopy|esetcontext|enteraccs|extractps|edeccssa|eaccept|ecreate|eextend|egetkey|endbr32|endbr64|enqcmds|erdinfo|eremove|ereport|eresume|etrackc|eblock|edbgrd|edbgwr|eenter|emodpe|emodpr|enqcmd|etrack|exitac|eexit|einit|eldbc|elduc|emodt|encls|enclu|enclv|enter|eadd|eaug|eldb|eldu|emms|epa|ewb)\\b"
