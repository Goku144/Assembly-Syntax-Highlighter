          "match": "(?i)\\b(?:kortestb|kortestd|kortestq|kortestw|kshiftlb|kshiftld|kshiftlq|kshiftlw|kshiftrb|kshiftrd|kshiftrq|kshiftrw|kunpckbw|kunpckdq|kunpckwd|kandnb|kandnd|kandnq|kandnw|ktestb|ktestd|ktestq|ktestw|kxnorb|kxnord|kxnorq|kxnorw|kaddb|kaddd|kaddq|kaddw|kandb|kandd|kandq|kandw|kmovb|kmovd|kmovq|kmovw|knotb|knotd|knotq|knotw|kxorb|kxord|kxorq|kxorw|korb|kord|korq|korw)\\b"
        },
        {
          "name": "keyword.control.instruction.l.x86asm",
          "match": "(?i)\\b(?:ldtilecfg|loadiwkey|ldmxcsr|lfence|loopcc|loopne|loopnz|lddqu|leave|lodsb|lodsd|lodsq|lodsw|loope|loopz|lzcnt|lahf|lgdt|lidt|lldt|lmsw|lock|lods|loop|leaq|lar|lds|lea|les|lfs|lgs|lsl|lss|ltr)\\b"
        },
        {
          "name": "keyword.control.instruction.m.x86asm",
          "match": "(?i)\\b(?:maskmovdqu|movdir64b|maskmovq|movmskpd|movmskps|movntdqa|movshdup|movsldup|monitor|movddup|movdiri|movdq2q|movhlps|movlhps|movntdq|movntpd|movntps|movq2dq|mpsadbw|mfence|movabs|movapd|movaps|movdqa|movdqu|movhpd|movhps|movlpd|movlps|movnti|movntq|movsxd|movupd|movups|maxpd|maxps|maxsd|maxss|minpd|minps|minsd|minss|movbe|movsb|movsd|movsq|movss|movsw|movsx|movzx|mulpd|mulps|mulsd|mulss|mwait|movd|movq|movs|mulx|mov|mul)\\b"
