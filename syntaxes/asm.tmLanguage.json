{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "x86/x64/ARM Assembly",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sections"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#data_labels"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#registers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#special_symbols"
    },
    {
      "include": "#instructions"
    },
    {
      "include": "#memory_operands"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#symbols"
    },
    {
      "include": "#structure"
    },
    {
      "include": "#macros"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.x86asm",
          "begin": ";",
          "end": "$",
          "patterns": [
            {
              "include": "#doc_comments"
            }
          ]
        },
        {
          "name": "comment.line.double-slash.x86asm",
          "begin": "//",
          "end": "$",
          "patterns": [
            {
              "include": "#doc_comments"
            }
          ]
        },
        {
          "name": "comment.line.hash.x86asm",
          "match": "^\\s*#.*$"
        },
        {
          "name": "comment.line.at-sign.x86asm",
          "match": "(^|\\s)(@.*$)",
          "captures": {
            "2": {
              "name": "comment.line.at-sign.x86asm"
            }
          }
        },
        {
          "name": "comment.block.x86asm",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#doc_comments"
            }
          ]
        }
      ]
    },
    "doc_comments": {
      "patterns": [
        {
          "name": "keyword.other.documentation.doxygen.x86asm",
          "match": "(?i)@(?:brief|param|returns?|note)\\b|\\bnote:"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.define.x86asm",
          "match": "(?i)(%)(define)\\s+([A-Za-z_.$?@][A-Za-z0-9_.$?@]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.definition.directive.percent.x86asm"
            },
            "2": {
              "name": "keyword.control.macro.define.x86asm"
            },
            "3": {
              "name": "entity.name.macro.define.x86asm"
            }
          }
        },
        {
          "name": "keyword.control.directive.assign.x86asm",
          "match": "(?i)(%)(assign)\\b",
          "captures": {
            "1": {
              "name": "punctuation.definition.directive.percent.x86asm"
            },
            "2": {
              "name": "keyword.control.directive.assign.x86asm"
            }
          }
        },
        {
          "name": "entity.name.type.class.storage-size.x86asm",
          "match": "(?i)\\b(?:db|dw|dd|dq|dt|do|dy|dz|resb|resw|resd|resq|rest|reso|resy|resz|byte|word|dword|qword|tword|oword|yword|zword)\\b"
        },
        {
          "name": "keyword.control.directive.equ.x86asm",
          "match": "(?i)\\bequ\\b"
        },
        {
          "name": "keyword.control.directive.nasm.x86asm",
          "match": "(?i)(%)(if|ifn|ifdef|ifndef|ifidn|ifidni|ifid|ifnum|ifstr|ifctx|ifmacro|ifenv|elif|elifn|elifdef|elifndef|elifidn|elifidni|elifid|elifnum|elifstr|elifctx|elifmacro|elifenv|else|endif|include|pathsearch|depend|use|push|pop|repl|arg|stacksize|local|line|error|warning|fatal|rep|endrep|exitrep|rotate|macro|imacro|endmacro|unmacro|undef|assign|iassign|strlen|substr|defstr|idefstr|deftok|ideftok|xdefine|ixdefine|use16|use32|use64)\\b",
          "captures": {
            "1": {
              "name": "punctuation.definition.directive.percent.x86asm"
            },
            "2": {
              "name": "keyword.control.directive.nasm.x86asm"
            }
          }
        },
        {
          "name": "keyword.control.directive.x86asm",
          "match": "\\.(?:section|text|data|bss|rodata|rdata|sdata|sbss|tdata|tbss|tcomm|init|fini|file|loc|line|cfi_[a-zA-Z_]+|gcc_except_table|ctors|dtors|ascii|asciz|string|string8|string16|string32|lcomm|comm|byte|hword|2byte|4byte|8byte|short|word|long|quad|octa|float|double|single|dword|xword|inst|inst.n|insn|option|attribute|variant_cc|ident|align|balign|p2align|even|org|space|skip|zero|fill|type|size|scl|def|endef|globl|global|weak|hidden|protected|internal|extern|local|set|equ|eqv|macro|endm|func|endfunc|thumb|thumb_func|arm|code|syntax|arch|arch_extension|cpu|fpu|eabi_attribute|intel_syntax|att_syntax|code16|code32|code64|note|debug|uleb128|sleb128|ent|end|frame|mask|fmask|set)\\b"
        },
        {
          "name": "keyword.control.directive.x86asm",
          "match": "\\b(?:extern|global|public|common|segment|section|absolute|bits|use16|use32|use64|default|rel|abs|org|align|cpu|import|export|group|library|module|end|proc|endp|db|dw|dd|dq|dt|do|dy|dz|dc|dcb|dcd|dcq|dci|ds|resb|resw|resd|resq|rest|reso|resy|resz|times)\\b"
        },
        {
          "name": "keyword.control.directive.offset.x86asm",
          "match": "\\bOFFSET\\b"
        }
      ]
    },
    "data_labels": {
      "patterns": [
        {
          "name": "constant.other.symbol.define.x86asm",
          "match": "(?i)^\\s*%(?:define|assign|xdefine|ixdefine|iassign)\\s+([A-Za-z_.$?@][A-Za-z0-9_.$?@]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.macro.define.x86asm"
            }
          }
        },
        {
          "name": "meta.constant.equ.x86asm",
          "match": "(?i)^\\s*([A-Za-z_.$?@][A-Za-z0-9_.$?@]*)\\s+(equ|=)\\b",
          "captures": {
            "1": {
              "name": "constant.other.symbol.equ.name.x86asm"
            },
            "2": {
              "name": "keyword.control.directive.equ.x86asm"
            }
          }
        },
        {
          "name": "variable.other.data.label.x86asm",
          "match": "(?i)^\\s*([A-Za-z_.$?@][A-Za-z0-9_.$?@]*):(?=\\s*(?:times\\s+[^;\\n]+\\s+)?(?:resb|resw|resd|resq|rest|reso|resy|resz|db|dw|dd|dq|dt|do|dy|dz|byte|word|dword|qword|tword|oword|yword|zword)\\b)",
          "captures": {
            "1": {
              "name": "variable.other.data.label.name.x86asm"
            }
          }
        },
        {
          "name": "variable.other.data.symbol.x86asm",
          "match": "(?i)^\\s*([A-Za-z_.$?@][A-Za-z0-9_.$?@]*)\\s+(?=(?:times\\s+[^;\\n]+\\s+)?(?:resb|resw|resd|resq|rest|reso|resy|resz|db|dw|dd|dq|dt|do|dy|dz|byte|word|dword|qword|tword|oword|yword|zword)\\b)",
          "captures": {
            "1": {
              "name": "variable.other.data.symbol.name.x86asm"
            }
          }
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.function.label.local.x86asm",
          "match": "^\\s*([.$][A-Za-z_.$?@][A-Za-z0-9_.$?@]*):",
          "captures": {
            "1": {
              "name": "entity.name.function.label.local.name.x86asm"
            }
          }
        },
        {
          "name": "entity.name.function.label.x86asm",
          "match": "^\\s*([A-Za-z_.$?@][A-Za-z0-9_.$?@]*):",
          "captures": {
            "1": {
              "name": "entity.name.function.label.name.x86asm"
            }
          }
        },
        {
          "name": "entity.name.tag.label.x86asm",
          "match": "^\\s*(L[A-Za-z0-9_.$?@]+):",
          "captures": {
            "1": {
              "name": "entity.name.tag.label.name.x86asm"
            }
          }
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "keyword.control.section.x86asm",
          "match": "\\.(section .(text|data|bss|tbss|tcomm))\\b"
        },
        {
          "name": "keyword.control.section.x86asm",
          "match": "\\.(text|data|bss|tbss|tcomm|rodata)\\b"
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "name": "keyword.control.instruction.arm.x86asm",
          "match": "(?i)\\b(?:adc|adcs|add|adds|adr|adrp|and|ands|asr|asrs|b|bal|beq|bne|bcs|bcc|bhs|blo|bmi|bpl|bvs|bvc|bhi|bls|bge|blt|bgt|ble|bx|bl|blr|br|cbnz|cbz|cmn|cmp|csel|cset|eor|eors|ldp|ldpsw|ldr|ldrb|ldrh|ldrsb|ldrsh|ldrsw|lsl|lsls|lsr|lsrs|madd|mla|mov|movk|movn|movt|movw|movz|mrs|msr|mul|mvn|neg|nop|orr|orrs|pop|push|ret|ror|rors|sbc|sbcs|sdiv|smull|stp|str|strb|strh|sub|subs|svc|sxtb|sxth|sxtw|tbnz|tbz|tst|udiv|umull|uxtb|uxth|wfe|wfi|yield|vadd|vsub|vmul|vdiv|vldr|vstr|vmov|fadd|fsub|fmul|fdiv|fcmp|fcsel|fcvt|scvtf|ucvtf)\\b"
        },
        {
          "name": "keyword.control.instruction.riscv.x86asm",
          "match": "(?i)\\b(?:add|addi|addiw|addw|and|andi|auipc|beq|bge|bgeu|blt|bltu|bne|call|c\\.add|c\\.addi|c\\.beqz|c\\.bnez|c\\.j|c\\.jal|c\\.jr|c\\.li|c\\.lw|c\\.mv|c\\.nop|c\\.ret|c\\.sw|csrr|csrrc|csrrci|csrrs|csrrsi|csrrw|csrrwi|div|divu|divuw|divw|ebreak|ecall|fadd\\.d|fadd\\.s|fcvt\\.d\\.s|fcvt\\.s\\.d|fdiv\\.d|fdiv\\.s|fld|flw|fmul\\.d|fmul\\.s|fsd|fsw|fsub\\.d|fsub\\.s|jal|jalr|j|la|lb|lbu|ld|lh|lhu|li|lui|lw|lwu|mul|mulh|mulhsu|mulhu|mulw|mv|neg|nop|not|or|ori|rem|remu|remuw|remw|ret|sb|sd|sh|sll|slli|slliw|sllw|slt|slti|sltiu|sltu|sra|srai|sraiw|sraw|srl|srli|srliw|srlw|sub|subw|sw|tail|xor|xori)\\b"
        },
        {
          "name": "keyword.control.instruction.mips.x86asm",
          "match": "(?i)\\b(?:abs|add|addi|addiu|addu|and|andi|beq|bgez|bgtz|blez|bltz|bne|break|div|divu|eret|j|jal|jalr|jr|la|lb|lbu|ld|lh|lhu|li|ll|lui|lw|lwc1|mfhi|mflo|move|movn|movz|mthi|mtlo|mul|mult|multu|neg|nop|nor|or|ori|rem|rol|ror|sb|sc|sd|sll|sllv|slt|slti|sltiu|sltu|sra|srav|srl|srlv|sub|subu|sw|swc1|syscall|teq|tge|tgeu|tlt|tltu|tne|xor|xori)\\b"
        },
        {
          "name": "keyword.control.instruction.v.x86asm",
          "match": "(?i)\\b(?:vaddpd|vaddps|vaddsd|vaddss|vaddsubpd|vaddsubps|vandnpd|vandnps|vandpd|vandps|vblendpd|vblendps|vblendvpd|vblendvps|vbroadcastsd|vbroadcastss|vcmppd|vcmpps|vcmpsd|vcmpss|vcomisd|vcomiss|vcvtdq2pd|vcvtdq2ps|vcvtpd2dq|vcvtpd2ps|vcvtps2dq|vcvtps2pd|vcvtsd2si|vcvtsd2ss|vcvtsi2sd|vcvtsi2ss|vcvtss2sd|vcvtss2si|vcvttpd2dq|vcvttps2dq|vcvttsd2si|vcvttss2si|vdivpd|vdivps|vdivsd|vdivss|vdppd|vdpps|vextractps|vhaddpd|vhaddps|vhsubpd|vhsubps|vinsertps|vlddqu|vldmxcsr|vmaskmovdqu|vmaskmovpd|vmaskmovps|vmaxpd|vmaxps|vmaxsd|vmaxss|vminpd|vminps|vminsd|vminss|vmovapd|vmovaps|vmovd|vmovddup|vmovdqa|vmovdqu|vmovhlps|vmovhpd|vmovhps|vmovlhps|vmovlpd|vmovlps|vmovmskpd|vmovmskps|vmovntdq|vmovntdqa|vmovntpd|vmovntps|vmovq|vmovsd|vmovshdup|vmovsldup|vmovss|vmovupd|vmovups|vmpsadbw|vmulpd|vmulps|vmulsd|vmulss|vorpd|vorps|vpabsb|vpabsd|vpabsw|vpackssdw|vpacksswb|vpackusdw|vpackuswb|vpaddb|vpaddd|vpaddq|vpaddsb|vpaddsw|vpaddusb|vpaddusw|vpaddw|vpalignr|vpand|vpandn|vpavgb|vpavgw|vpblendvb|vpblendw|vpcmpeqb|vpcmpeqd|vpcmpeqq|vpcmpeqw|vpcmpgtb|vpcmpgtd|vpcmpgtq|vpcmpgtw|vpextrb|vpextrd|vpextrq|vpextrw|vphaddd|vphaddsw|vphaddw|vphsubd|vphsubsw|vphsubw|vpinsrb|vpinsrd|vpinsrq|vpinsrw|vpmaddubsw|vpmaddwd|vpmaxsb|vpmaxsd|vpmaxsw|vpmaxub|vpmaxud|vpmaxuw|vpminsb|vpminsd|vpminsw|vpminub|vpminud|vpminuw|vpmovmskb|vpmuldq|vpmulhrsw|vpmulhuw|vpmulhw|vpmulld|vpmullw|vpmuludq|vpor|vpsadbw|vpshufb|vpshufd|vpshufhw|vpshuflw|vpshufw|vpsignb|vpsignd|vpsignw|vpslld|vpslldq|vpsllq|vpsllw|vpsrad|vpsraw|vpsrld|vpsrldq|vpsrlq|vpsrlw|vpsubb|vpsubd|vpsubq|vpsubsb|vpsubsw|vpsubusb|vpsubusw|vpsubw|vptest|vpunpckhbw|vpunpckhdq|vpunpckhqdq|vpunpckhwd|vpunpcklbw|vpunpckldq|vpunpcklqdq|vpunpcklwd|vpxor|vrcpps|vrcpss|vroundpd|vroundps|vroundsd|vroundss|vrsqrtps|vrsqrtss|vshufpd|vshufps|vsqrtpd|vsqrtps|vsqrtsd|vsqrtss|vstmxcsr|vsubpd|vsubps|vsubsd|vsubss|vucomisd|vucomiss|vunpckhpd|vunpckhps|vunpcklpd|vunpcklps|vxorpd|vxorps)\\b"
        },
        {
          "name": "keyword.control.instruction.a.x86asm",
          "match": "(?i)\\b(?:aesdecwide128kl|aesdecwide256kl|aesencwide128kl|aesencwide256kl|aeskeygenassist|aesdec128kl|aesdec256kl|aesenc128kl|aesenc256kl|aesdeclast|aesenclast|addsubpd|addsubps|aesdec|aesenc|aesimc|andnpd|andnps|addpd|addps|addsd|addss|andpd|andps|adcx|adox|andn|arpl|aaa|aad|aam|aas|adc|add|and)\\b"
        },
        {
